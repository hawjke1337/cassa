# Production environment variables — Phase 17 minimal reference.
# This is a TEMPLATE. Copy to .env.production and fill actual values.
# Phase 18 will contain full list (caddy TLS, backup destinations, Sentry DSN, Redis URL).

# === Required for app boot ===
DATABASE_URL=postgresql://astore:CHANGE_ME@postgres:5432/astore_erp
NEXTAUTH_SECRET=CHANGE_ME  # generate: openssl rand -base64 32
NEXTAUTH_URL=https://erp.example.com
NODE_ENV=production

# === Production seed bootstrap (Phase 17 BUILD-02) ===
# ONLY set SEED_ALLOW_PROD=true when INTENTIONALLY bootstrapping a fresh prod DB.
# After first `SEED_ALLOW_PROD=true pnpm prisma db seed`:
#  1. Temp admin password printed to stdout ONCE — copy it to a password manager.
#  2. Login as admin, change password immediately (Phase 18 UI force-flow).
#  3. REMOVE SEED_ALLOW_PROD from environment (not needed again).
# SEED_ALLOW_PROD=true  # keep commented in normal operation

# === Phase 18 preview (full list in DEPLOYMENT.md when ready) ===
# SENTRY_DSN=
# REDIS_URL=
# BACKUP_DESTINATION=
